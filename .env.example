# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=<generate with: python -c "import secrets; print(secrets.token_hex(32))">

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentic_purchase

# ── Redis ─────────────────────────────────────────────────────────────────────
# Use rediss:// (TLS) in all non-local environments (C-03)
REDIS_URL=redis://localhost:6379/0

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Stripe ────────────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY and STRIPE_WEBHOOK_SECRET are two separate keys (C-01).
# Do NOT use the same value for both.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Obtain from: Stripe Dashboard -> Webhooks -> your endpoint -> Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── JWT session tokens (C-02) ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=<generate with: openssl rand -hex 32>
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── Rate limiting (H-06) ──────────────────────────────────────────────────────
RATE_LIMIT_SAGA_PER_MINUTE=5
RATE_LIMIT_SESSION_PER_MINUTE=10
RATE_LIMIT_ENABLED=true

# ── eBay ──────────────────────────────────────────────────────────────────────
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
# Sandbox keys (SBX- prefix) must use sandbox URL; omit for production
EBAY_BASE_URL=https://api.sandbox.ebay.com

# ── SerpApi ───────────────────────────────────────────────────────────────────
SERPAPI_KEY=

# ── Supermemory ───────────────────────────────────────────────────────────────
SUPERMEMORY_API_KEY=

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=
