# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-64-char-hex-string
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentic_purchase
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_SAGA_TTL_SECONDS=1800

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL_ORCHESTRATOR=gpt-4o
OPENAI_MODEL_EXECUTOR=gpt-4o-mini

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=usd

# ── Etsy ──────────────────────────────────────────────────────────────────────
ETSY_API_KEY=...
ETSY_BASE_URL=https://openapi.etsy.com/v3

# ── eBay ──────────────────────────────────────────────────────────────────────
EBAY_APP_ID=...
EBAY_CERT_ID=...
EBAY_DEV_ID=...
EBAY_BASE_URL=https://api.ebay.com

# ── SerpApi ───────────────────────────────────────────────────────────────────
SERPAPI_KEY=...
SERPAPI_BASE_URL=https://serpapi.com

# ── Supermemory ───────────────────────────────────────────────────────────────
SUPERMEMORY_API_KEY=...
SUPERMEMORY_BASE_URL=https://api.supermemory.ai

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Checkout velocity ─────────────────────────────────────────────────────────
CHECKOUT_MAX_ATTEMPTS_PER_HOUR=3

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
